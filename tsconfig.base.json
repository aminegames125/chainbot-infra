{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@chainbot/shared":   ["./packages/shared/src/index.ts"],
      "@chainbot/shared/*": ["./packages/shared/src/*"],
      "@chainbot/config":   ["./packages/config/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", "coverage"]
}
