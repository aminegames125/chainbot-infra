{
  "name": "chainbot-monorepo",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.33.2"
  },
  "scripts": {
    "dev": "pnpm --filter bot dev & pnpm --filter web dev & pnpm --filter docs dev",
    "dev:bot": "pnpm --filter bot dev",
    "dev:web": "pnpm --filter web dev",
    "dev:docs": "pnpm --filter docs dev",
    "dev:all": "pnpm node & pnpm dev",
    "node": "pnpm --filter contracts exec hardhat node",
    "build": "pnpm --filter web build && pnpm --filter docs build",
    "test": "vitest run --workspace vitest.workspace.ts --reporter=verbose",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:ui": "vitest --workspace vitest.workspace.ts --ui",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "test:contracts": "pnpm --filter contracts exec hardhat test",
    "test:all": "pnpm test && pnpm test:contracts",
    "contracts:deploy": "pnpm --filter contracts exec hardhat run scripts/deploy.js",
    "contracts:deploy:local": "pnpm --filter contracts exec hardhat run scripts/deploy.js --network localhost",
    "lint": "pnpm -r exec eslint . --ext .ts,.tsx",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "clean": "find . -name 'node_modules' -not -path './node_modules/*' -type d | xargs rm -rf && rm -rf pnpm-lock.yaml",
    "setup": "pnpm install && pnpm docker:up",
    "setup:local": "pnpm setup && echo 'Please run pnpm node in another terminal, then pnpm contracts:deploy:local'"
  },
  "devDependencies": {
    "vitest": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^6.0.3",
    "eslint": "^10.2.1",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0"
  }
}